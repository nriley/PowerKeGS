#include "types.rez"
#include "main.h"


/* Version resource */
resource rVersion (1) {
    {
        1,          /* Major version number in BCD */
        0,          /* Minor version number in BCD */
        0,          /* Bug version number in BCD */
        release,	/* Development phase */
        $00         /* Release number */
    },
    verUS,
    "ADB Explorer",
    "Copyright \$A9 2025-26, Nicholas Riley"
};

resource rIcon (1) {
	$8000,                  // kind
	$0017,                  // height (23)
	$0014,                  // width (20) = 460

	$"",

	$"0FFF0000 00000000 0000FFFF FFFF0000 00000000 FFFFFFFF FF000000 0000FFFF FFFFFF00 00000000 0FFF0000 FFF00000 00000000 0000FFF0 00000000 00000000 FFF00000 00000000 00000F00 000FFF00 00000000 00FFFFFF FFF00000 00000FFF FFFFFFF0 00000000 FFFFFFFF FFF00000 0000FFF0 000FFF00 00000000 FFF00000 00000000 0000FFF0 00000000 0FFF0000 0F000000 0000FFFF FFFF0000 00000000 FFFFFFFF FF000000 0000FFFF FFFFFF00 00000000 0FFF0000 FFF00000 00000000 0000FFF0 00000000 00000000 FFF00000 00000000 0000FFF0 00000000 00000000 0F000000 0000";
};

/* Bundle resource */
resource rBundle (1, preload, nospecialmemory) {
	1,			// rIcon ID
	1,			// rBundle ID
	{ }			// no documents supported
};


/* Menu bars */
resource rMenuBar (MENU_BAR) {
    {
        APPLE_MENU,
        FILE_MENU,
        EDIT_MENU
    };
};


/* Menus */
resource rMenu (APPLE_MENU) {
    APPLE_MENU,
    refIsResource * menuTitleRefShift
    + refIsResource * itemRefShift
    + fAllowCache,
    APPLE_MENU,
    {
        APPLE_ABOUT
    };
};
resource rPString (APPLE_MENU, noCrossBank) {"@"};

resource rMenu (FILE_MENU) {
    FILE_MENU,
    refIsResource * menuTitleRefShift
    + refIsResource * itemRefShift
    + fAllowCache,
    FILE_MENU,
    {
        FILE_NEW,
        FILE_OPEN,
        FILE_SAVE,
        FILE_SAVE_AS,
        FILE_CLOSE,
        FILE_PAGE_SETUP,
        FILE_PRINT,
        FILE_QUIT
    };
};
resource rPString (FILE_MENU, noCrossBank) {" File "};

resource rMenu (EDIT_MENU) {
    EDIT_MENU,
    refIsResource * menuTitleRefShift
    + refIsResource * itemRefShift
    + fAllowCache,
    EDIT_MENU,
    {
        EDIT_UNDO,
        EDIT_CUT,
        EDIT_COPY,
        EDIT_PASTE,
        EDIT_CLEAR
    };
};
resource rPString (EDIT_MENU, noCrossBank) {" Edit "};


